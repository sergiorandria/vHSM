# Login
curl -s -X POST http://localhost:8080/api/v1/login \
  -H "Content-Type: application/json" \
  -d '{"username":"prof1","password":"profpass123"}'

TOKEN="<paste token>"

# Should work if the user's role includes ReadThesis
curl -s http://localhost:8080/api/v1/theses \
  -H "Authorization: Bearer $TOKEN"

# Should 403 if the user's role isn't admin/professeurs
curl -s -X POST http://localhost:8080/api/v1/submissions \
  -H "Authorization: Bearer $TOKEN" \
  -F "ThesisId=t1" -F "Grade=A" -F "Title=Test" -F "Date=2026-07-05" \
  -F "Document=@/path/to/file.pdf"
